;; ww/test — minimal test framework
;;
;; Usage: (def t (perform import "ww/test"))
;;        (t :deftest "addition" (fn []
;;          (t :assert= 4 (+ 2 2))
;;          (t :assert-true (> 3 1))))
;;        (t :run-tests)
;;
;; Tests are registered with deftest and executed with run-tests.
;; Failures throw with a structured ex-info; run-tests catches and
;; reports. Catches dispatch on :glia.error/type.

;; --- Test registry ---
;;
;; Atom-backed: `def` from inside a fn body writes the closure's own root,
;; not this module's, so the previous (def *tests* ...) registry silently
;; registered nothing (wetware/ww#574). The atom is captured by the
;; closures below and shared across invocations.

(def *tests* (atom (list)))

;; deftest — register a named test function
;; (deftest "my-test" (fn [] (assert= 1 1)))
(defn deftest [test-name test-fn]
  (reset! *tests* (concat (deref *tests*) (list {:name test-name :fn test-fn}))))

;; --- Assertions ---

;; assert= — assert two values are equal
(defn assert= [expected actual]
  (when-not (= expected actual)
    (throw (ex-info "assertion failed"
                    {:type :assert=
                     :expected expected
                     :actual actual}))))

;; assert-true — assert value is truthy
(defn assert-true [val]
  (when-not val
    (throw (ex-info "assertion failed"
                    {:type :assert-true
                     :value val}))))

;; assert-false — assert value is falsy
(defn assert-false [val]
  (when val
    (throw (ex-info "assertion failed"
                    {:type :assert-false
                     :value val}))))

;; assert-nil — assert value is nil
(defn assert-nil [val]
  (when-not (nil? val)
    (throw (ex-info "assertion failed"
                    {:type :assert-nil
                     :value val}))))

;; assert-throws — assert that a thunk throws.
;; Wildcard catch returns :threw on any throw; :no-throw on success.
;; (assert-throws (fn [] (throw "boom")))
(defn assert-throws [thunk]
  (let [outcome (try (do (thunk) :no-throw)
                     (catch _ _e :threw))]
    (when (= outcome :no-throw)
      (throw (ex-info "expected throw, got success"
                      {:type :assert-throws})))))

;; --- Runner ---

;; run-tests — execute all registered tests, print results
;; Returns {:passed N :failed N :errors [...]}
(defn run-tests []
  (let [tests (deref *tests*)
        results
        (map
          (fn [test]
            (let [test-name (get test :name)
                  test-fn (get test :fn)
                  ;; Wildcard catch: success → :ok marker, throw → captured error.
                  outcome (try (do (test-fn) {:status :pass :name test-name})
                               (catch _ e {:status :fail :name test-name :error e}))]
              (if (= (get outcome :status) :pass)
                (do (println (str "  PASS  " test-name))
                    outcome)
                (do (println (str "  FAIL  " test-name ": " (get outcome :error)))
                    outcome))))
          tests)
        passed (count (filter (fn [r] (= (get r :status) :pass)) results))
        failed (count (filter (fn [r] (= (get r :status) :fail)) results))
        errors (filter (fn [r] (= (get r :status) :fail)) results)]
    (println "")
    (println (str passed " passed, " failed " failed, " (count tests) " total"))
    {:passed passed
     :failed failed
     :errors (map (fn [e] {:name (get e :name) :error (get e :error)}) errors)}))

;; reset-tests — clear the test registry
(defn reset-tests []
  (reset! *tests* (list)))
